@page
@using System.Linq
@model Baltsped.Tools.Server.Pages.Te.LookupModel
@{
    ViewData["Title"] = "Просмотр содержимого ТЕ";
}

<header class="mb-8">
    <h1 class="text-3xl font-bold tracking-tight text-brand-text mb-2">Просмотр содержимого ТЕ</h1>
    <p class="text-brand-text-muted text-sm max-w-2xl">
        Поиск и анализ содержимого транспортных единиц. Введите номер ТЕ для получения детальной информации о вложенных DM-кодах и SKU.
    </p>
</header>

<div class="card-brand p-6 mb-8">
    <form method="get" asp-page="/Te/Lookup" class="flex flex-col md:flex-row gap-4">
        <div class="flex-1 relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-brand-text-dim w-4.5 h-4.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
                <circle cx="11" cy="11" r="6.5" />
                <path d="m16 16 4 4" stroke-linecap="round" />
            </svg>
            <input asp-for="TeCode" type="text" placeholder="Введите номер ТЕ (например, TE-99281)" class="input-field pl-10" />
        </div>
        <div class="flex gap-2">
            <button type="submit" class="btn-primary min-w-[120px]">Найти</button>
            <a asp-page="/Te/Lookup" class="btn-secondary" aria-label="Очистить">
                <svg class="w-4.5 h-4.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M5 7h14M9 7V5h6v2m-7 3v7m4-7v7m4-7v7M7 7l1 12h8l1-12" stroke-linecap="round" stroke-linejoin="round" /></svg>
            </a>
        </div>
    </form>

    @if (Model.SearchPerformed && !Model.ModelState.IsValid)
    {
        <div asp-validation-summary="All" class="mt-4 p-4 rounded-brand border border-brand-error/30 bg-brand-error/10 text-brand-error"></div>
    }
</div>

@if (Model.Rows.Count > 0)
{
    var uniqueArticlesCount = Model.Rows.Select(row => row.ArticleCode).Where(value => !string.IsNullOrWhiteSpace(value)).Distinct(StringComparer.Ordinal).Count();

    <div class="space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <div class="card-brand p-4 bg-brand-surface-light/20">
                <p class="text-[10px] text-brand-text-dim uppercase font-bold mb-1">Всего записей</p>
                <p class="text-2xl font-mono font-bold">@Model.Rows.Count</p>
            </div>
            <div class="card-brand p-4 bg-brand-surface-light/20">
                <p class="text-[10px] text-brand-text-dim uppercase font-bold mb-1">Уникальных SKU</p>
                <p class="text-2xl font-mono font-bold">@uniqueArticlesCount</p>
            </div>
            <div class="card-brand p-4 bg-brand-surface-light/20">
                <p class="text-[10px] text-brand-text-dim uppercase font-bold mb-1">Общее кол-во</p>
                <p class="text-2xl font-mono font-bold">@Model.Rows.Count</p>
            </div>
            <div class="card-brand p-4 bg-brand-surface-light/20">
                <p class="text-[10px] text-brand-text-dim uppercase font-bold mb-1">Статус ТЕ</p>
                <div class="flex items-center gap-2 mt-1">
                    <svg class="w-4 h-4 text-brand-success" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 12 2 2 4-4"/><circle cx="12" cy="12" r="9"/></svg>
                    <span class="text-sm font-bold text-brand-success">Проверено</span>
                </div>
            </div>
        </div>

        <div class="table-container">
            <table class="table-brand">
                <thead>
                <tr>
                    <th>№</th>
                    <th>ТЕ</th>
                    <th>Артикул</th>
                    <th>Наименование</th>
                    <th>Штрихкод</th>
                    <th>Код партии</th>
                </tr>
                </thead>
                <tbody>
                @for (var i = 0; i < Model.Rows.Count; i++)
                {
                    var row = Model.Rows[i];
                    <tr>
                        <td class="font-mono text-brand-text-dim">@(i + 1)</td>
                        <td class="font-mono font-bold text-brand-accent">@row.TeCode</td>
                        <td class="font-mono">@row.ArticleCode</td>
                        <td>@row.ArticleName</td>
                        <td class="font-mono">@row.Barcode</td>
                        <td class="text-xs text-brand-text-dim">@row.BatchCode</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}
else if (Model.SearchPerformed && Model.ModelState.IsValid)
{
    <div class="card-brand p-12 flex flex-col items-center justify-center text-center">
        <div class="w-16 h-16 bg-brand-surface-light rounded-full flex items-center justify-center mb-4 border border-brand-border">
            <svg class="w-8 h-8 text-brand-text-dim" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="11" cy="11" r="6.5"/><path d="m16 16 4 4" stroke-linecap="round"/></svg>
        </div>
        <h3 class="text-xl font-bold mb-2">Ничего не найдено</h3>
        <p class="text-brand-text-muted max-w-md">
            По вашему запросу <span class="text-brand-text font-mono">"@Model.TeCode"</span> данных не обнаружено. Проверьте правильность ввода номера ТЕ.
        </p>
    </div>
}
else
{
    <div class="card-brand p-12 border-dashed border-2 flex flex-col items-center justify-center text-center opacity-50">
        <svg class="w-12 h-12 text-brand-text-dim mb-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M4 5.5 12 2l8 3.5v13L12 22l-8-3.5v-13Z" /><path d="M12 2v20M4 5.5l8 3.5 8-3.5" /></svg>
        <p class="text-brand-text-muted">Ожидание ввода номера транспортной единицы...</p>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
