@page
@using System.Linq
@model Baltsped.Tools.Server.Pages.Te.LookupModel
@{
    ViewData["Title"] = "Просмотр содержимого ТЕ";
}

<div class="viewer-head">
    <h1 class="viewer-head__title">Просмотр содержимого ТЕ</h1>
    <p class="viewer-head__description">
        Поиск и анализ содержимого транспортной единицы. Введите номер ТЕ для получения детальной информации о вложенных DM-кодах и артикулах.
    </p>
</div>

<div class="viewer-search-panel">
    <form method="get" asp-page="/Te/Lookup" class="viewer-search-bar">
        <div class="viewer-search-input">
            <svg viewBox="0 0 24 24" aria-hidden="true">
                <circle cx="11" cy="11" r="6.5" fill="none" stroke="currentColor" stroke-width="1.7" />
                <path d="m16 16 4 4" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
            </svg>

            <input asp-for="TeCode"
                   placeholder="Введите номер ТЕ"
                   autocomplete="off"
                   spellcheck="false"
                   maxlength="32"
                   autofocus />
        </div>

        <button type="submit" class="app-btn app-btn--primary">Найти</button>

        <a asp-page="/Te/Lookup" class="app-btn app-btn--secondary app-btn--icon" aria-label="Очистить">
            <svg viewBox="0 0 24 24" aria-hidden="true" style="width:18px;height:18px;">
                <path d="M5 7h14M9 7V5h6v2m-7 3v7m4-7v7m4-7v7M7 7l1 12h8l1-12" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
        </a>
    </form>

    @if (Model.SearchPerformed && !Model.ModelState.IsValid)
    {
        <div asp-validation-summary="All" class="app-alert"></div>
    }
</div>

@if (Model.Rows.Count > 0)
{
    var uniqueArticlesCount = Model.Rows
        .Select(row => row.ArticleCode)
        .Where(value => !string.IsNullOrWhiteSpace(value))
        .Distinct(StringComparer.Ordinal)
        .Count();

    var uniqueBarcodesCount = Model.Rows
        .Select(row => row.Barcode)
        .Where(value => !string.IsNullOrWhiteSpace(value))
        .Distinct(StringComparer.Ordinal)
        .Count();

    <div class="viewer-summary">
        <div class="viewer-summary__item">
            <div class="viewer-summary__label">Всего записей</div>
            <div class="viewer-summary__value">@Model.Rows.Count</div>
        </div>

        <div class="viewer-summary__item">
            <div class="viewer-summary__label">Уникальных штрихкодов</div>
            <div class="viewer-summary__value">@uniqueBarcodesCount</div>
        </div>

        <div class="viewer-summary__item">
            <div class="viewer-summary__label">Уникальных артикулов</div>
            <div class="viewer-summary__value">@uniqueArticlesCount</div>
        </div>
    </div>

    <div class="viewer-table-wrap">
        <div class="viewer-toolbar">
            <div class="viewer-toolbar__status" id="searchResultInfo"></div>

            <div class="viewer-toolbar__filter">
                <label for="tableFilterInput">Быстрый фильтр по таблице</label>
                <input type="search"
                       id="tableFilterInput"
                       placeholder="ТЕ, артикул, наименование, штрихкод, код партии"
                       autocomplete="off" />
            </div>
        </div>

        <div class="table-responsive">
            <table class="table-brand lookup-table mb-0">
                <thead>
                    <tr>
                        <th scope="col">№</th>
                        <th scope="col">ТЕ</th>
                        <th scope="col">Артикул</th>
                        <th scope="col">Наименование</th>
                        <th scope="col">Штрихкод</th>
                        <th scope="col">Код партии</th>
                    </tr>
                </thead>
                <tbody>
                    @for (var i = 0; i < Model.Rows.Count; i++)
                    {
                        var row = Model.Rows[i];

                        <tr class="lookup-row" data-row-index="@i" data-page-row="true">
                            <td>@(i + 1)</td>
                            <td>@row.TeCode</td>
                            <td>@row.ArticleCode</td>
                            <td>@row.ArticleName</td>
                            <td class="table-brand__code">@row.Barcode</td>
                            <td>@row.BatchCode</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="table-pagination">
            <span class="table-pagination__info" id="paginationInfo"></span>
            <button type="button" class="app-btn app-btn--secondary" id="prevPageBtn" aria-label="Предыдущая страница">&larr;</button>
            <button type="button" class="app-btn app-btn--secondary" id="nextPageBtn" aria-label="Следующая страница">&rarr;</button>
        </div>
    </div>
}
else if (Model.SearchPerformed && Model.ModelState.IsValid)
{
    <div class="page-empty page-empty--large">
        <div class="page-empty__inner">
            <div class="page-empty__icon">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M4 5.5 12 2l8 3.5v13L12 22l-8-3.5v-13Z" fill="none" stroke="currentColor" stroke-width="1.7" />
                    <path d="M12 2v20M4 5.5l8 3.5 8-3.5" fill="none" stroke="currentColor" stroke-width="1.7" />
                </svg>
            </div>
            <h2 class="page-empty__title">Ничего не найдено</h2>
            <p class="page-empty__text">По указанному номеру ТЕ записи отсутствуют.</p>
        </div>
    </div>
}
else
{
    <div class="page-empty page-empty--large">
        <div class="page-empty__inner">
            <div class="page-empty__icon">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M4 5.5 12 2l8 3.5v13L12 22l-8-3.5v-13Z" fill="none" stroke="currentColor" stroke-width="1.7" />
                    <path d="M12 2v20M4 5.5l8 3.5 8-3.5" fill="none" stroke="currentColor" stroke-width="1.7" />
                </svg>
            </div>
            <h2 class="page-empty__title">Ожидание поиска</h2>
            <p class="page-empty__text">Введите номер транспортной единицы, чтобы загрузить её содержимое.</p>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const pageSize = 25;
            const rows = Array.from(document.querySelectorAll('.lookup-row[data-page-row="true"]'));
            const filterInput = document.getElementById("tableFilterInput");
            const searchResultInfo = document.getElementById("searchResultInfo");
            const info = document.getElementById("paginationInfo");
            const prevBtn = document.getElementById("prevPageBtn");
            const nextBtn = document.getElementById("nextPageBtn");

            if (rows.length === 0 || !info || !prevBtn || !nextBtn) {
                return;
            }

            let filteredRows = rows.slice();
            let currentPage = 1;

            function getTotalPages() {
                return Math.max(1, Math.ceil(filteredRows.length / pageSize));
            }

            function renderPage(page) {
                const totalPages = getTotalPages();
                currentPage = Math.min(Math.max(1, page), totalPages);

                const start = (currentPage - 1) * pageSize;
                const end = start + pageSize;

                rows.forEach(function (row, index) {
                    const filteredIndex = filteredRows.indexOf(row);
                    const visible = filteredIndex >= start && filteredIndex < end;

                    row.style.display = filteredIndex >= 0 && visible ? "" : "none";

                    const rowNumberCell = row.querySelector("td:first-child");
                    if (rowNumberCell) {
                        rowNumberCell.textContent = filteredIndex >= 0
                            ? String(filteredIndex + 1)
                            : String(index + 1);
                    }
                });

                info.textContent = "Страница " + currentPage + " из " + totalPages + " (всего записей: " + filteredRows.length + ")";
                prevBtn.disabled = currentPage <= 1;
                nextBtn.disabled = currentPage >= totalPages;

                if (searchResultInfo) {
                    searchResultInfo.textContent = filteredRows.length === rows.length
                        ? "Показаны все записи"
                        : "Найдено записей: " + filteredRows.length;
                }
            }

            function applyFilter() {
                const query = (filterInput?.value || "").trim().toLowerCase();

                filteredRows = rows.filter(function (row) {
                    if (!query) {
                        return true;
                    }

                    const rowText = row.textContent?.toLowerCase() || "";
                    return rowText.includes(query);
                });

                renderPage(1);
            }

            prevBtn.addEventListener("click", function () {
                if (currentPage > 1) {
                    renderPage(currentPage - 1);
                }
            });

            nextBtn.addEventListener("click", function () {
                if (currentPage < getTotalPages()) {
                    renderPage(currentPage + 1);
                }
            });

            if (filterInput) {
                filterInput.addEventListener("input", applyFilter);
            }

            renderPage(1);
        });
    </script>
}
