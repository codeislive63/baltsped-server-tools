@page "/dm/replace"
@model Baltsped.Tools.Server.Pages.Dm.ReplaceModel
@{
    ViewData["Title"] = "Замена DM-кодов";
}

<header class="mb-8">
    <h1 class="text-3xl font-bold tracking-tight text-brand-text mb-2">Замена DM-кодов</h1>
    <p class="text-brand-text-muted text-sm max-w-2xl">
        Инструмент для оперативной замены поврежденных или некорректных DataMatrix кодов в рамках транспортной единицы.
    </p>
</header>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <div class="lg:col-span-1 space-y-6">
        <div class="card-brand p-6">
            <h3 class="text-sm font-bold uppercase tracking-wider text-brand-text-muted mb-4 flex items-center gap-2">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M4 4h16M7 12h10M10 20h4" stroke-linecap="round"/></svg>
                Поиск ТЕ
            </h3>
            <form method="post" asp-page-handler="Search" class="space-y-4">
                <div>
                    <label asp-for="Search.TeCode" class="block text-xs font-bold text-brand-text-dim uppercase mb-1.5">Номер ТЕ</label>
                    <input asp-for="Search.TeCode" type="text" class="input-field" placeholder="Напр. TE-99281" />
                </div>
                <button type="submit" class="btn-primary w-full">Загрузить данные</button>
            </form>
        </div>

        @if (Model.Errors.Count > 0)
        {
            <div class="p-4 rounded-brand border flex gap-3 animate-in zoom-in-95 duration-300 bg-brand-error/10 border-brand-error/30 text-brand-error">
                <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="12" r="9"/><path d="M12 8v5m0 3h.01" stroke-linecap="round"/></svg>
                <div>
                    @foreach (var error in Model.Errors)
                    {
                        <p class="text-sm font-medium">@error</p>
                    }
                </div>
            </div>
        }

        @if (Model.UpdateSummary is not null)
        {
            var hasUpdates = Model.UpdateSummary.UpdatedCount > 0;
            <div class="p-4 rounded-brand border flex gap-3 animate-in zoom-in-95 duration-300 @(hasUpdates ? "bg-brand-success/10 border-brand-success/30 text-brand-success" : "bg-brand-warning/10 border-brand-warning/30 text-brand-warning")">
                <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="12" r="9"/><path d="m8 12 2.5 2.5L16 9" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <p class="text-sm font-medium">@(hasUpdates ? "DM-код успешно обновлен." : "Изменений не внесено.")</p>
            </div>
        }
    </div>

    <div class="lg:col-span-2">
        @if (Model.HasResults)
        {
            <div class="table-container">
                <table class="table-brand">
                    <thead>
                    <tr>
                        <th>DM Код</th>
                        <th>SKU / Партия</th>
                        <th>Статус</th>
                        <th class="text-right">Действие</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var row in Model.Results)
                    {
                        <tr>
                            <td class="font-mono font-bold">@row.Barcode</td>
                            <td class="font-mono text-xs">@row.BatchName</td>
                            <td>
                                <span class="badge badge-success">active</span>
                            </td>
                            <td class="text-right">
                                <form method="post" asp-page-handler="UpdateRow" class="inline-flex gap-2 items-center js-dm-update-form">
                                    <input type="hidden" name="teCode" value="@Model.Search.TeCode" />
                                    <input type="hidden" name="itemId" value="@row.ItemId" />
                                    <input type="text" name="newDm" class="input-field py-1 px-2 text-xs w-44" placeholder="Новый DM" autocomplete="off" spellcheck="false" required />
                                    <button type="submit" class="btn-secondary py-1 px-3 text-xs">Заменить</button>
                                </form>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="card-brand p-12 flex flex-col items-center justify-center text-center border-dashed border-2 opacity-50 h-full">
                <svg class="w-12 h-12 text-brand-text-dim mb-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M4 7h10m0 0-3-3m3 3-3 3M20 17H10m0 0 3-3m-3 3 3 3" stroke-linecap="round" stroke-linejoin="round" /></svg>
                <p class="text-brand-text-muted">Загрузите данные ТЕ для начала работы</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelectorAll(".js-dm-update-form").forEach(function (form) {
            const dmInput = form.querySelector("input[name='newDm']");

            if (!dmInput) {
                return;
            }

            form.addEventListener("submit", function () {
                dmInput.value = dmInput.value.replace(/\s+/g, "").trim();
            });
        });
    </script>
}
