@page
@model Baltsped.Tools.Server.Pages.IndexModel
@{
    ViewData["Title"] = "Каталог инструментов";

    string GetCategory(string title) => title switch
    {
        "Печать листов вброса" => "Документы",
        "Проверка содержимого ТЕ" => "Инструмент",
        "Просмотр содержимого ТЕ" => "Транспортные единицы",
        "Создание заказа ДМ" => "Инструмент",
        "DM-коды" => "Маркировка",
        "Составление ЗНТ" => "Склад",
        _ => "Инструмент"
    };
}

<div class="page-hero">
    <span class="page-hero__eyebrow">Baltsped Tools</span>
    <h1 class="page-hero__title">Каталог инструментов</h1>
    <p class="page-hero__description">
        Внутренние операционные инструменты для работы со складскими данными, транспортными единицами и маркировкой.
    </p>
</div>

<p class="section-lead">
    Выберите нужный модуль. Доступные инструменты открываются сразу, остальные отмечены как находящиеся в разработке.
</p>

<div class="tool-grid">
    @foreach (var tool in Model.Tools)
    {
        var cardClass = tool.IsAvailable ? "tool-card is-available" : "tool-card is-disabled";
        var stateClass = tool.IsAvailable ? "tool-state is-ready" : "tool-state is-soon";
        var stateText = tool.IsAvailable ? "Доступен" : "Недоступен";
        var category = GetCategory(tool.Title);

        <article class="@cardClass">
            <div class="tool-card__body">
                <div class="tool-card__meta">
                    <span class="tool-chip">@category</span>
                    <span class="@stateClass">@stateText</span>
                </div>

                <h2 class="tool-card__title">@tool.Title</h2>
                <p class="tool-card__description">@tool.Description</p>
            </div>

            <div class="tool-card__footer">
                @if (tool.IsAvailable)
                {
                    <a href="@tool.Route" class="app-btn app-btn--primary">Открыть</a>
                }
                else
                {
                    <button type="button" class="app-btn app-btn--secondary" disabled>В разработке</button>
                }
            </div>
        </article>
    }
</div>
