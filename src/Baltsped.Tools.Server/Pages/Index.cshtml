@page
@model Baltsped.Tools.Server.Pages.IndexModel
@{
    ViewData["Title"] = "Каталог инструментов";
}

<style>
    .catalog-hero {
        background: linear-gradient(135deg, #f8fbff 0%, #eef5ff 100%);
        border-radius: 1rem;
    }

    .catalog-eyebrow {
        display: inline-block;
        padding: .35rem .75rem;
        font-size: .8rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: #0d6efd;
        background-color: rgba(13, 110, 253, .08);
        border-radius: 999px;
    }

    .catalog-card {
        height: 100%;
        border: 0;
        border-radius: 1rem;
        transition: transform 160ms ease, box-shadow 160ms ease;
    }

        .catalog-card.catalog-card-active:hover {
            transform: translateY(-6px);
            box-shadow: 0 1rem 2rem rgba(13, 110, 253, .12) !important;
        }

    .catalog-card-disabled {
        opacity: .82;
        background: linear-gradient(180deg, #fcfcfd 0%, #f7f8fa 100%);
    }

    .catalog-badge {
        padding: .35rem .65rem;
        font-size: .75rem;
        font-weight: 600;
        border-radius: 999px;
    }

    .catalog-badge-ready {
        color: #146c43;
        background-color: #d1f7df;
    }

    .catalog-badge-soon {
        color: #6c757d;
        background-color: #edf0f3;
    }

    .catalog-description {
        min-height: 3rem;
    }
</style>

<div class="card border-0 shadow-sm catalog-hero mb-4">
    <div class="card-body p-4 p-lg-5 text-center">
        <span class="catalog-eyebrow mb-3">Baltsped Tools</span>
        <h1 class="h3 mb-3">Каталог инструментов</h1>
        <p class="text-secondary mb-0">
            Выберите нужный модуль для складской операции
        </p>
    </div>
</div>

<div class="row g-4">
    @foreach (var tool in Model.Tools)
    {
        var cardClass = tool.IsAvailable
        ? "catalog-card catalog-card-active"
        : "catalog-card catalog-card-disabled";

        <div class="col-12 col-md-6 col-xl-4">
            <div class="card shadow-sm @cardClass">
                <div class="card-body d-flex flex-column p-4">
                    <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                        <h2 class="h5 mb-0">@tool.Title</h2>

                        @if (tool.IsAvailable)
                        {
                            <span class="catalog-badge catalog-badge-ready">Доступно</span>
                        }
                        else
                        {
                            <span class="catalog-badge catalog-badge-soon">Скоро</span>
                        }
                    </div>

                    <p class="text-secondary catalog-description mb-4">
                        @tool.Description
                    </p>

                    <div class="mt-auto">
                        @if (tool.IsAvailable)
                        {
                            <a href="@tool.Route" class="btn btn-primary px-4">Открыть</a>
                        }
                        else
                        {
                            <button type="button" class="btn btn-outline-secondary px-4" disabled>
                                В разработке
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>
